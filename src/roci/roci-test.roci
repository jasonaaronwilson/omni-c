// A tiny abstraction for a named test

let make_test = fn(name, thunk) {
  return make_list(name, thunk);
};

let test_name = fn(test) {
  return list_get(test, 0);
};

let test_thunk = fn(test) {
  return list_get(test, 1);
};

// ----------------------------------------------------------------------
// The test API.

// Global State

let ROCI_TESTS = make_list();
let ROCI_LAST_TEST_PASSED = false;
let ROCI_NUM_PASS = 0;
let ROCI_NUM_FAIL = 0;

let add_test = fn(name, thunk) {
  list_push(ROCI_TESTS, make_test(name, thunk));
};

let pass_test = fn() {
  ROCI_LAST_TEST_PASSED = true;
  ROCI_NUM_PASS = iadd(ROCI_NUM_PASS, 1);
};

let fail_test = fn() {
  ROCI_LAST_TEST_PASSED = false;
  ROCI_NUM_FAIL = iadd(ROCI_NUM_FAIL, 1);
};

// ----------------------------------------------------------------------

// Move this somewhere else...
let list_map = fn(lst, func) {
  let result = make_list();
  list_for_each(lst, fn(x) {
      list_push(result, func(x));
    });
  return result;
};

let list_add_all = fn(lst0, lst1) {
  list_for_each(lst1, fn(x) {
      list_push(lst0, x);
    });
};

// ----------------------------------------------------------------------

let run_tests = fn() {
  print_string("Running tests...\n");
  list_for_each(ROCI_TESTS, fn(test) {
      ROCI_LAST_TEST_PASSED = false;
      let thunk = test_thunk(test);
      thunk();
      // The current bug is that we seem to have the wrong envrionment
      // here since "test" is no longer defined.
      if (ROCI_LAST_TEST_PASSED) {
	print_string(string_append("TEST PASSED: ", test_name(test), "\n"));
      } else {
	print_string(string_append("TEST FAILED: ", test_name(test), "\n"));
      }
    });
};

let string_equal_or_fail = fn(expected, computed) {
  if (string_equal(expected, computed)) {
    println(string_append("Expected '", expected, "' but got '", computed, "'"));
    fail_test();
  }
};

add_test("empty_test",
	 fn() {
	   pass_test();
	 });

add_test("string_append_test",
	 fn() {
	   let str = string_append("abc", "123");
	   if (string_equal("abc123", str)) {
	     pass_test();
	   } else {
	     fail_test();
	   }
	 });

add_test("string_not_equal_test",
	 fn() {
	   if (string_equal("abc123", "")) {
	     fail_test();
	   } else {
	     pass_test();
	   }
	 });

add_test("list_test",
	 fn() {
	   let lst = make_list("a", "b", "c", "d");
	   let second = list_get(lst, 1);
	   if (not(string_equal("b", second))) {
	     fail_test();
	   }
	   list_push(lst, "e");
	   let last = list_get(lst, 4);
	   if (not(string_equal("e", last))) {
	     fail_test();
	   }
	   pass_test();
	 });

add_test("string_substring_test",
	 fn() {
	   let substr = string_substring("0123456789", 1, 3);
	   if (string_equal("12", substr)) {
	     pass_test();
	   } else {
	     fail_test();
	   }
	 });

add_test("list_map_test",
	 fn() {
	   let lst = make_list("a", "b", "c", "d");
	   let xformed = list_map(lst, fn(x) {
	       return string_append("letter=", x);
	     });
	   if (string_equal("letter=b", list_get(xformed, 1))) {
	     pass_test();
	   } else {
	     fail_test();
	   }
	 });

add_test("getenv_test",
	 fn() {
	   let value = getenv("USER");
	   println(value);
	   if (is_string(value)) {
	     pass_test();
	     return;
	   }
	   fail_test();
	 });

add_test("list_add_all_test",
	 fn() {
	   let lst1 = make_list("a", "b", "c");
	   let lst2 = make_list("1", "2", "3");
	   let lst3 = make_list("foo", "bar", "baz", "aa", "bb", "cc");
	   list_add_all(lst1, lst2);
	   list_add_all(lst1, lst3);
	   list_add_all(lst1, lst3);
	   list_add_all(lst1, lst3);
	   list_add_all(lst1, lst3);
	   list_add_all(lst1, lst3);
	   pass_test();
	 });

add_test("list_add_test",
	 fn() {
	   let str = "asdf";
	   let lst1 = make_list("a");
	   list_push(lst1, "b");
	   list_push(lst1, string_append(str, "jkl"));
	   pass_test();
	 });

add_test("call_closure_test",
	 fn() {
	   let shared = "ASDF";
	   let closure = fn() {
	     return shared;
	   };
	   let result = closure();
	   if (string_equal("ASDF", result)) {
	     pass_test();
	   } else {
	     fail_test();
	   }
	 });

add_test("return_closure_test",
	 fn() {
	   let shared = "ASDF";
	   let return_closure = fn() {
	     return fn(y) {
	       let x = string_append(y, shared);
	       let z = string_append(x, "");
	       return z;
	     };
	   };
	   let closure = return_closure();
	   let result = closure("FOO");
	   if (string_equal("FOOASDF", result)) {
	     pass_test();
	   } else {
	     fail_test();
	   }
	 });

add_test("int_relations_test",
	 fn() {
	   if (not(ilt(10, 20))) {
	     fail_test();
	   }
	   if (ilt(11, 10)) {
	     fail_test();
	   }
	   if (not(ilte(20, 20))) {
	     fail_test();
	   }
	   if (ilte(30, 20)) {
	     fail_test();
	   }
	   if (not(iequal(30, 30))) {
	     fail_test();
	   }
	   if (iequal(30, 31)) {
	     fail_test();
	   }
	   if (not(igte(30, 10))) {
	     fail_test();
	   }
	   if (not(igte(10, 10))) {
	     fail_test();
	   }
	   if (not(igt(30, 10))) {
	     fail_test();
	   }
	   if (igt(30, 30)) {
	     fail_test();
	   }
	   if (igt(30, 35)) {
	     fail_test();
	   }
	   pass_test();
	 });

add_test("bitwise_test",
	 fn() {
	   if (not(iequal(16, bit_shr(32, 1)))) {
	     fail_test();
	   }
	   if (not(iequal(64, bit_shl(32, 1)))) {
	     fail_test();
	   }
	   pass_test();
	 });

add_test("hex_encoding_test",
	 fn() {

	   let nibble_to_hex_digit = fn(nibble) {
	     if (ilt(nibble, 10)) {
	       return ascii_to_string(iadd(nibble, 48)); // 48 is ASCII '0'
	     } else {
	       return ascii_to_string(iadd(97, isub(nibble, 10))); // 97 for 'a'
	     }
	   };

	   let byte_to_hex_digits = fn(byte) {
	     return string_append(nibble_to_hex_digit(bit_shr(byte, 4)),
				  nibble_to_hex_digit(bit_and(byte, 15)));
	   };

	   string_equal_or_fail("00", byte_to_hex_digits(0));
	   string_equal_or_fail("09", byte_to_hex_digits(9));
	   string_equal_or_fail("0a", byte_to_hex_digits(10));
	   string_equal_or_fail("0f", byte_to_hex_digits(15));
	   string_equal_or_fail("ff", byte_to_hex_digits(255));

	   pass_test();
	 });

// println(ROCI_TESTS);

run_tests();

if (iequal(ROCI_NUM_FAIL, 0)) {
  exit(0);
 } else {
  exit(1);
 }
