// A tiny abstraction for a named test

let make_test = fn(name, thunk) {
  return make_list(name, thunk);
};

let test_name = fn(test) {
  return list_get(test, 0);
};

let test_thunk = fn(test) {
  return list_get(test, 1);
};

// ----------------------------------------------------------------------
// The test API.

// Global State

let ROCI_TESTS = make_list();
let ROCI_LAST_TEST_PASSED = false;
let ROCI_NUM_PASS = 0;
let ROCI_NUM_FAIL = 0;

let add_test = fn(name, thunk) {
  list_push(ROCI_TESTS, make_test(name, thunk));
};

let pass_test = fn() {
  ROCI_LAST_TEST_PASSED = true;
  ROCI_NUM_PASS = iadd(ROCI_NUM_PASS, 1);
};

let fail_test = fn() {
  ROCI_LAST_TEST_PASSED = false;
  ROCI_NUM_FAIL = iadd(ROCI_NUM_FAIL, 1);
};

// ----------------------------------------------------------------------

// Move this somewhere else...
let list_map = fn(lst, func) {
  let result = make_list();
  list_for_each(lst, fn(x) {
      list_push(result, func(x));
    });
  return result;
};

let list_add_all = fn(lst0, lst1) {
  list_for_each(lst1, fn(x) {
      list_push(lst0, x);
    });
};

// ----------------------------------------------------------------------

let run_tests = fn() {
  print_string("Running tests...\n");
  list_for_each(ROCI_TESTS, fn(test) {
      ROCI_LAST_TEST_PASSED = false;
      let thunk = test_thunk(test);
      thunk();
      // The current bug is that we seem to have the wrong envrionment
      // here since "test" is no longer defined.
      if (ROCI_LAST_TEST_PASSED) {
	print_string(string_append("TEST PASSED: ", test_name(test), "\n"));
      } else {
	print_string(string_append("TEST FAILED: ", test_name(test), "\n"));
      }
    });
};

add_test("empty_test",
	 fn() {
	   pass_test();
	 });

add_test("string_append_test",
	 fn() {
	   let str = string_append("abc", "123");
	   if (string_equal("abc123", str)) {
	     pass_test();
	   } else {
	     fail_test();
	   }
	 });

add_test("string_not_equal_test",
	 fn() {
	   if (string_equal("abc123", "")) {
	     fail_test();
	   } else {
	     pass_test();
	   }
	 });

add_test("list_test",
	 fn() {
	   let lst = make_list("a", "b", "c", "d");
	   let second = list_get(lst, 1);
	   if (not(string_equal("b", second))) {
	     fail_test();
	   }
	   list_push(lst, "e");
	   let last = list_get(lst, 4);
	   if (not(string_equal("e", last))) {
	     fail_test();
	   }
	   pass_test();
	 });

add_test("string_substring_test",
	 fn() {
	   let substr = string_substring("0123456789", 1, 3);
	   if (string_equal("12", substr)) {
	     pass_test();
	   } else {
	     fail_test();
	   }
	 });

add_test("list_map_test",
	 fn() {
	   let lst = make_list("a", "b", "c", "d");
	   let xformed = list_map(lst, fn(x) {
	       return string_append("letter=", x);
	     });
	   if (string_equal("letter=b", list_get(xformed, 1))) {
	     pass_test();
	   } else {
	     fail_test();
	   }
	 });

add_test("getenv_test",
	 fn() {
	   let value = getenv("USER");
	   println(value);
	   if (is_string(value)) {
	     pass_test();
	     return;
	   }
	   fail_test();
	 });

add_test("list_add_all_test",
	 fn() {
	   let lst1 = make_list("a", "b", "c");
	   let lst2 = make_list("1", "2", "3");
	   let lst3 = make_list("foo", "bar", "baz", "aa", "bb", "cc");
	   list_add_all(lst1, lst2);
	   list_add_all(lst1, lst3);
	   list_add_all(lst1, lst3);
	   list_add_all(lst1, lst3);
	   list_add_all(lst1, lst3);
	   list_add_all(lst1, lst3);
	   pass_test();
	 });

// println(ROCI_TESTS);

run_tests();

if (iequal(ROCI_NUM_FAIL, 0)) {
  exit(0);
 } else {
  exit(1);
 }
