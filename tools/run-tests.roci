//
// This is the tree wide test runner for roci. In this case, each test
// is essentially at least one executable invocation, however, in many
// cases, that one executable may itself run many "unit tests".
// 

//
// This is how I'm testing the test runner right now!
//
// OMNI_C_ROOT=/home/jawilson/src/omni-c BUILD_DIR=/home/jawilson/src/omni-c/build-dir /home/jawilson/src/omni-c/build-dir/bin/omni-c roci --script /home/jawilson/src/omni-c/tools/run-tests.roci /home/jawilson/src/omni-c/tests/always-passing-test.sh /home/jawilson/src/omni-c/tests/always-failing-test.sh
//

let omni_c_root = getenv("OMNI_C_ROOT");
let build_dir = getenv("BUILD_DIR");
let omni_c_exec = string_append(build_dir, "/bin/omni-c");

let check_environment_variables = fn() {

  if (is_string(omni_c_root)) {
    println(string_append("OMNI_C_ROOT = ", omni_c_root));
  } else {
    println("ERROR: OMNI_C_ROOT environment variable not set.");
    exit(1);
  }

  if (is_string(build_dir)) {
    println(string_append("BUILD_DIR = ", build_dir));
  } else  {
    println("ERROR: BUILD_DIR environment variable not set.");
    exit(1);
  }
};

check_environment_variables();

// ======================================================================

let success = 0;
let failure = 0;
let failed_tests = make_list();
let no_golden_tests = make_list();

let test_success = fn(filename) {
  success = iadd(success, 1);
};

let test_fail = fn(filename) {
  failure = iadd(failure, 1);
  list_push(failed_tests, filename);
};

