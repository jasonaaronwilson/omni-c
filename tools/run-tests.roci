let get_test_executor = fn(filename) {
  if (string_ends_with(filename, ".sh")) {
    return script_test_executor;
  }
  // TODO(jawilson): be more specific
  if (string_contains(filename, "lib/")) {
    return lib_unit_test_executor;
  }
  if (string_ends_with(filename, ".expr")) {
    return expr_test_executor;
  }
  if (string_ends_with(filename, ".stmt")) {
    return stmt_test_executor;
  }
  let contents = read_file(filename);
  if (buffer_contains(contents, "main(")) {
    return execute_test_executor;
  } else {
    return parse_test_executor;
  }
};

let check_shell_command = fn(shell_result, filename) {
  if (not(iequal(shell_exit_code(shell_result), 0))) {
    println(shell_stdout(shell_result));
    println("A shell command returned a non-zero exit code.");
    test_fail(filename);
  } else {
    test_success(filename);
  }
};

let script_test_executor = fn(filename) {
  let command_line = make_list(filename);
  let shell_result = shell(command_line);
  check_shell_command(shell_result, filename);
};

let lib_unit_test_executor = fn(filename) {
  let lib_archive = string_append(build_dir, "/bin/lib.oar");
  let command_line = make_list(omni_c_exec, "test", lib_archive, filename);
  let shell_result = shell(command_line);
  check_shell_command(shell_result, filename);
};

let expr_test_executor = fn(filename) {
  let command_line = make_list(omni_c_exec, "test", filename);
  let shell_result = shell(command_line);
  check_shell_command(shell_result, filename);
};

let stmt_test_executor = fn(filename) {
  let command_line = make_list(omni_c_exec, "test", filename);
  let shell_result = shell(command_line);
  check_shell_command(shell_result, filename);
};

let get_omni_c_executable = fn() {
  let exe = getenv("OMNI_C_EXECUTABLE");
  if (is_string(exe)) {
    return exe;
  } else {
    return string_append(build_dir, "/bin/omni-c");
  }
};

// local start_time = get_timestamp()

let run_tests = fn() {
  list_for_each(command_line_args(), fn(arg) {
      println("------------------------------------------------------------------------");
      println(string_append("Running: ", arg));
      println("------------------------------------------------------------------------");
      let runner = get_test_executor(arg);
      runner(arg);
    });
};

run_tests();

println("======================================================================");

let show_summary = fn() {
  if (igt(success, 0)) { 
    if (iequal(failure, 0)) {
      println(string_append("\nPassed ", to_string(success), " tests."));
    }
  }

  if (iequal(failure, 0)) {
    exit(0);
  } else {
    list_for_each(failed_tests, fn(failed_test) {
	println(string_append("FAILURE: ", failed_test));
      });
    println(string_append("\nPassed ", to_string(success), " tests."));
    println(string_append("Failed ", to_string(failure), " tests."));
    exit(1);
  }
};
show_summary();
